{
  "name": "@ansvar/gleif-mcp",
  "version": "1.0.0",
  "description": "Offline-first GLEIF MCP server for Legal Entity Identifier (LEI) verification. Self-contained SQLite database with 2.1M LEI records and daily sync.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "gleif-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist && find . -name '*.tsbuildinfo' -not -path './node_modules/*' -delete",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http-server.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js",
    "build:db": "tsx scripts/build-db.ts",
    "sync": "tsx scripts/sync-gleif.ts",
    "prepare": "test -f dist/index.js || npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gleif",
    "lei",
    "legal-entity-identifier",
    "banking",
    "compliance",
    "offline-first",
    "sqlite"
  ],
  "author": "Ansvar Systems <hello@ansvar.eu> (https://ansvar.eu)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ansvar-Systems/GLEIF-MCP.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "data",
    "scripts",
    "src"
  ],
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "better-sqlite3": "^12.6.2"
  }
}
